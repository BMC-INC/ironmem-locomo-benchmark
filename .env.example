# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Anthropic — answerer (Claude) and optional Claude judge.
# If ANTHROPIC_API_KEY is already exported in your shell you can leave this blank.
ANTHROPIC_API_KEY=

# OpenAI — default LLM judge (gpt-4o), the industry-standard judge for LoCoMo.
OPENAI_API_KEY=

# IronMem REST server (default shown).
IRONMEM_URL=http://localhost:37778
